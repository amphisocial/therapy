# TherapyAgent environment
# Do not commit real .env files. Keep this file as .env.example only.

PORT=3060
NODE_ENV=production
SITE_ORIGIN=https://therapyagent.athenabot.ai

# Postgres database dedicated to TherapyAgent.
DATABASE_URL=postgresql://therapyagent:CHANGE_ME@127.0.0.1:5432/therapyagent
PGSSL=false

# JWT secret: generate with `openssl rand -base64 48`
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# AI provider. For PHI workflows, only enable external LLM use after BAA/Healthcare Addendum is signed.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Safety gate. Keep false unless legal/compliance approves sending PHI to the AI provider.
ALLOW_PHI_TO_LLM=false

# Optional email invite provider.
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@therapyagent.athenabot.ai
