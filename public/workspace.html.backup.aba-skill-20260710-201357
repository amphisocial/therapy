<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>TherapyAgent Workspace</title>
  <meta name="description" content="TherapyAgent secure clinical documentation workspace.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body data-page="workspace">
  <header class="topbar app-topbar">
    <div class="brand">
      <div class="mark">TA</div>
      <div>
        <strong>TherapyAgent</strong>
        <span>Secure clinical workspace</span>
      </div>
    </div>
    <div id="userNav" class="user-nav">
      <a href="/security-compliance.html">Security</a>
      <a href="/terms.html">Terms</a>
      <span id="welcomeUser">Welcome</span>
      <button id="logoutBtn" class="btn small secondary">Logoff</button>
    </div>
  </header>

  <main class="workspace-main">
    <section class="workspace" id="workspace">
      <aside class="sidebar">
        <h3>Workspace</h3>
        <button data-panel="dashboard" class="active">Dashboard</button>
        <button data-panel="analytics">Data Analytics</button>
        <button data-panel="aiWorkbench">AI Workbench</button>
        <button data-panel="patients">Patients</button>
        <button data-panel="inbox">Inbox</button>
        <button data-panel="sessions">Session Log</button>
        <button data-panel="behaviors">Behavior Events</button>
        <button data-panel="plans">Therapy Plans</button>
        <button data-panel="incidents">Incidents</button>
        <button data-panel="reports">AI Reports</button>
        <button data-panel="admin">Admin & Roles</button>
      </aside>

      <section class="panel active" id="dashboard">
        <div class="panel-head"><div><p class="eyebrow">Today</p><h2>Workspace dashboard</h2></div><button class="btn small" id="refreshAll">Refresh</button></div>
        <div class="metric-grid">
          <div class="metric"><span id="metricPatients">0</span><label>Patients</label></div>
          <div class="metric"><span id="metricInbox">0</span><label>Inbox items</label></div>
          <div class="metric"><span id="metricDrafts">0</span><label>Draft records</label></div>
          <div class="metric"><span id="metricReviews">0</span><label>Under review</label></div>
        </div>
        <div class="notice">Open any page on the left. Lists show saved items; double-click a row or click Open to view/edit. New creates a fresh form.</div>
      </section>


      <section class="panel" id="analytics">
        <div class="panel-head">
          <div>
            <p class="eyebrow">Clinical intelligence</p>
            <h2>Data Analytics</h2>
          </div>
          <button class="btn small" id="refreshAnalytics" type="button">Refresh analytics</button>
        </div>
        <div class="notice">Track organization trends, patient risk signals, workload, and documentation quality. Risk signals are decision-support indicators and require BCBA review.</div>
        <div id="analyticsContent" class="analytics-content">Loading analytics...</div>
      </section>

      <section class="panel" id="aiWorkbench">
        <div class="panel-head">
          <div>
            <p class="eyebrow">ABA-skilled assistant</p>
            <h2>AI Workbench</h2>
          </div>
          <button class="btn small" id="refreshAiWorkbench" type="button">Refresh context</button>
        </div>
        <div class="notice">Talk to an ABA-skilled BCBA support agent that uses TherapyAgent records as context. The agent supports clinical documentation and plan preparation, but does not replace clinician judgment.</div>
        <section class="form-card ai-workbench-card">
          <div class="form-grid">
            <label>Patient context
              <select id="aiWorkbenchPatient"><option value="">Organization-level / no single patient</option></select>
            </label>
            <label>Date range
              <select id="aiWorkbenchRange">
                <option value="30">Last 30 days</option>
                <option value="90" selected>Last 90 days</option>
                <option value="180">Last 180 days</option>
                <option value="365">Last 365 days</option>
              </select>
            </label>
            <label>Workbench mode
              <select id="aiWorkbenchMode">
                <option value="plan_review">Plan review preparation</option>
                <option value="behavior_analysis">Behavior pattern analysis</option>
                <option value="incident_review">Incident review</option>
                <option value="report_drafting">Report drafting support</option>
                <option value="predictive_signals">Predictive risk signals</option>
                <option value="general">General BCBA question</option>
              </select>
            </label>
            <label>ABA Knowledge Base
              <select id="aiWorkbenchKnowledge">
                <option value="patient_records">Patient records only</option>
                <option value="org_approved" disabled>Org-approved ABA documents coming soon</option>
              </select>
            </label>
            <label class="span-2">Ask the ABA-Skilled BCBA Agent
              <textarea id="aiWorkbenchQuestion" placeholder="Example: Prepare me for this patient's plan review. What trends, antecedents, interventions, and data gaps should I consider?"></textarea>
            </label>
          </div>
          <div class="form-actions">
            <button class="btn" id="runAiWorkbench" type="button">Ask ABA-Skilled BCBA Agent</button>
            <button class="btn secondary" id="clearAiWorkbench" type="button">Clear</button>
          </div>
          <div id="aiWorkbenchMsg" class="message"></div>
        </section>
        <section class="ai-workbench-output" id="aiWorkbenchOutput" hidden></section>
        <section class="ai-knowledge-card">
          <h3>ABA Knowledge Base</h3>
          <p>Future enhancement: upload organization-approved ABA resources, clinical templates, public-domain guidance, and licensed materials. TherapyAgent will not preload copyrighted ABA books unless your organization has rights to use them.</p>
        </section>
        <section class="ai-workbench-history">
          <h3>Recent AI Workbench activity</h3>
          <div id="aiWorkbenchHistory" class="table-wrap"></div>
        </section>
      </section>

      <section class="panel" id="patients">
        <div class="panel-head"><div><p class="eyebrow">Patient records</p><h2>Patients</h2></div><button class="btn small" id="newPatientBtn">New patient</button></div>
        <form id="patientForm" class="form-card" hidden>
          <div class="form-grid">
            <label>First name<input name="first_name" required></label>
            <label>Last name<input name="last_name" required></label>
            <label>Date of birth<input name="date_of_birth" type="date"></label>
            <label>MRN / External ID<input name="external_id"></label>
            <label>Guardian name<input name="guardian_name"></label>
            <label>Guardian phone<input name="guardian_phone"></label>
            <label>Guardian email<input name="guardian_email" type="email"></label>
            <label>Diagnosis / Program<input name="diagnosis"></label>
            <label class="span-2">Insurance<textarea name="insurance"></textarea></label>
          </div>
          <div class="form-actions"><button class="btn">Save patient</button><button class="btn secondary" type="button" id="cancelPatientBtn">Cancel</button></div>
        </form>
        <div id="patientList" class="table-wrap"></div>
        <section id="patientDetail" class="detail-panel" hidden>
          <div class="panel-head"><div><p class="eyebrow">Patient detail</p><h2 id="patientDetailTitle">Patient</h2></div><button class="btn small secondary" id="closePatientDetail">Back to patients</button></div>
          <div class="tabs" id="patientTabs">
            <button data-patient-tab="sessions" class="active">Sessions</button>
            <button data-patient-tab="behaviors">Behaviors</button>
            <button data-patient-tab="plans">Plans</button>
            <button data-patient-tab="reports">Reports</button>
            <button data-patient-tab="incidents">Incidents</button>
          </div>
          <div id="patientTabContent" class="table-wrap"></div>
        </section>
      </section>

      <section class="panel" id="inbox">
        <div class="panel-head"><div><p class="eyebrow">Review workflow</p><h2>Inbox</h2></div><button class="btn small" id="refreshInbox">Refresh inbox</button></div>
        <h3>Pending my review</h3><div id="assignedInbox" class="table-wrap"></div>
        <h3>Returned to me</h3><div id="returnedInbox" class="table-wrap"></div>
      </section>

      <section class="panel resource-panel" id="sessions" data-resource="sessions"><div class="resourceMount"></div></section>
      <section class="panel resource-panel" id="behaviors" data-resource="behaviors"><div class="resourceMount"></div></section>
      <section class="panel resource-panel" id="plans" data-resource="plans"><div class="resourceMount"></div></section>
      <section class="panel resource-panel" id="incidents" data-resource="incidents"><div class="resourceMount"></div></section>
      <section class="panel resource-panel" id="reports" data-resource="reports"><div class="resourceMount"></div></section>

      <section class="panel" id="admin">
        <div class="panel-head"><div><p class="eyebrow">Administration</p><h2>Users, roles, permissions</h2></div><button class="btn small" id="refreshAdmin">Refresh admin</button></div>
        <div class="tabs" id="adminTabs">
          <button data-admin-tab="users" class="active">Users</button>
          <button data-admin-tab="roles">Role permissions</button>
          <button data-admin-tab="attachments">Attachment Setup</button>
        </div>
        <div id="adminUsersTab">
          <form id="adminAddUserForm" class="form-card">
            <h3>Add user / invite</h3>
            <div class="form-grid">
              <label>First name<input name="firstName" required></label>
              <label>Last name<input name="lastName" required></label>
              <label>Email / Login<input name="email" type="email" required></label>
              <label>Initial password<input name="initialPassword" type="password" required autocomplete="new-password"><small>Minimum 10 chars with uppercase, lowercase, number, and special character.</small></label>
              <label>Role<select name="role" class="roleSelect"></select></label>
              <label class="check legal-check span-2"><input name="adminTermsAttested" type="checkbox" required> <span>I attest that this user is authorized by our organization to use TherapyAgent and will operate under our organization policies and the <a href="/terms.html" target="_blank" rel="noopener">TherapyAgent Terms and Conditions</a>.</span></label>
            </div>
            <div class="form-actions"><button class="btn">Create user</button></div>
            <div id="inviteOutput" class="notice" hidden></div>
          </form>
          <div id="adminUserList" class="table-wrap"></div>
        </div>
        <div id="adminRolesTab" hidden>
          <div class="notice">Check permissions by role. MVP enforcement still primarily uses role-level controls in the API, but this matrix is stored for the admin model and future fine-grained checks.</div>
          <div id="roleMatrix" class="matrix-wrap"></div>
          <div class="form-actions"><button class="btn" id="saveRoleMatrix">Save role permissions</button></div>
        </div>
        <div id="adminAttachmentsTab" hidden>
          <section class="form-card attachment-setup-card">
            <h3>Attachment Setup</h3>
            <p class="muted">Enable file attachments for this organization. When enabled, TherapyAgent initializes the organization prefix inside the S3 bucket configured in <code>.env</code>. S3 folders are virtual, so the app creates marker objects and stores files under the org prefix automatically.</p>
            <div id="attachmentSetupStatus" class="notice">Loading attachment setup...</div>
            <div class="form-actions">
              <label class="check"><input type="checkbox" id="attachmentsEnabledToggle"> Attach File</label>
              <button class="btn" id="saveAttachmentSetup" type="button">Save Attachment Setup</button>
              <button class="btn secondary" id="refreshAttachmentSetup" type="button">Refresh</button>
            </div>
            <div id="attachmentSetupMsg" class="message"></div>
          </section>
        </div>
      </section>
    </section>

  </main>

  <script src="/app.js"></script>
</body>
</html>
