  const rows = (await pool.query(
    `SELECT ${cfg.select}
     FROM ${cfg.table} s
     LEFT JOIN patients p ON p.id = s.patient_id AND p.org_id = s.org_id
     LEFT JOIN users cu ON cu.id = s.${cfg.createdByField}
     LEFT JOIN users mu ON mu.id = s.modified_by
